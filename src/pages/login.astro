---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ログイン - YAMADA LAB ANP Portal">
  <div class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-blue-500/5 rounded-full blur-3xl"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M40 0L0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>

    <div class="relative w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-3">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-xl shadow-blue-500/30">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div class="text-left">
            <div class="text-lg font-bold text-white">YAMADA LAB</div>
            <div class="text-xs text-slate-500">OpenRoaming ANP Portal</div>
          </div>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-[#0d1627]/70 backdrop-blur-xl border border-[#1a2540] rounded-2xl p-8 shadow-2xl">
        <h1 class="text-lg font-bold text-center text-white mb-2">管理者ログイン</h1>
        <p class="text-xs text-slate-500 text-center mb-8">
          GitHub Enterprise SSO (yamada-lab-llc) でサインイン
        </p>

        <!-- GitHub Enterprise SSO button -->
        <a
          href="https://yamada-lab-llc.ghe.com/enterprises/yamada-lab-llc/sso"
          class="w-full flex items-center justify-center gap-3 px-4 py-3.5 rounded-xl bg-[#24292f] text-white font-semibold text-sm hover:bg-[#2f363d] active:scale-[0.98] transition-all shadow-sm"
        >
          <!-- GitHub mark -->
          <svg width="20" height="20" viewBox="0 0 16 16" fill="white" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          GitHub Enterprise でサインイン
        </a>

        <!-- Enterprise info -->
        <div class="mt-4 flex items-center gap-2 px-3 py-2.5 rounded-xl bg-[#0f1a30]/50 border border-[#1a2540]">
          <svg class="w-4 h-4 text-slate-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <div>
            <div class="text-[11px] text-slate-400 font-medium">yamada-lab-llc.ghe.com</div>
            <div class="text-[10px] text-slate-600">Google Workspace SAML でSSO認証</div>
          </div>
        </div>

        <p class="text-[11px] text-slate-600 text-center mt-5 leading-relaxed">
          アクセス権の付与は組織の管理者に<br/>お問い合わせください
        </p>
      </div>
    </div>
  </div>

  <script>
    // Service Worker 登録
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(console.error);
    }

    // 既にセッションがあればダッシュボードへ
    (async () => {
      const params = new URLSearchParams(window.location.search);
      try {
        const res  = await fetch('/auth/status');
        const data = await res.json();
        if (data.authenticated) {
          window.location.replace(params.get('next') || '/dashboard/');
        }
      } catch {}
    })();
  </script>
</Layout>
