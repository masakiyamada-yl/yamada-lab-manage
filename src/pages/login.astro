---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ログイン - YAMADA LAB ANP Portal">
  <div class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-blue-500/5 rounded-full blur-3xl"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M40 0L0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>

    <div class="relative w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-3">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-xl shadow-blue-500/30">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div class="text-left">
            <div class="text-lg font-bold text-white">YAMADA LAB</div>
            <div class="text-xs text-slate-500">OpenRoaming ANP Portal</div>
          </div>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-[#0d1627]/70 backdrop-blur-xl border border-[#1a2540] rounded-2xl p-8 shadow-2xl">
        <h1 class="text-lg font-bold text-center text-white mb-2">管理者ログイン</h1>
        <p class="text-xs text-slate-500 text-center mb-8">組織のSSOアカウントでサインインしてください</p>

        <!-- SSO buttons -->
        <div class="space-y-3">
          <a
            href="/dashboard"
            class="w-full flex items-center justify-center gap-3 px-4 py-3.5 rounded-xl bg-white text-gray-800 font-semibold text-sm hover:bg-gray-50 transition-all shadow-sm"
          >
            <svg width="18" height="18" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google でサインイン
          </a>

          <a
            href="/dashboard"
            class="w-full flex items-center justify-center gap-3 px-4 py-3.5 rounded-xl bg-[#0078d4] text-white font-semibold text-sm hover:bg-[#0067b8] transition-all"
          >
            <svg width="18" height="18" viewBox="0 0 23 23">
              <path fill="#f35325" d="M1 1h10v10H1z"/><path fill="#81bc06" d="M12 1h10v10H12z"/>
              <path fill="#05a6f0" d="M1 12h10v10H1z"/><path fill="#ffba08" d="M12 12h10v10H12z"/>
            </svg>
            Microsoft でサインイン
          </a>

          <div class="flex items-center gap-3 my-1">
            <div class="flex-1 h-px bg-[#1a2540]"></div>
            <span class="text-[11px] text-slate-600">または</span>
            <div class="flex-1 h-px bg-[#1a2540]"></div>
          </div>

          <a
            href="/dashboard"
            class="w-full flex items-center justify-center gap-3 px-4 py-3.5 rounded-xl bg-[#0f1a30]/70 border border-[#1a2540] text-slate-400 text-sm font-medium hover:bg-[#0f1a30] hover:text-slate-300 transition-all"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            SAML SSO でサインイン
          </a>
        </div>

        <p class="text-[11px] text-slate-600 text-center mt-6 leading-relaxed">
          アクセス権の付与は組織の管理者に<br/>お問い合わせください
        </p>
      </div>
    </div>
  </div>
</Layout>
