---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';

const certs = [
  { cn:'ap01.yamada-lab.co.jp',    serial:'A1B2C3D4', key:'RSA 4096',     issued:'2026-03-01', expires:'2028-03-01', days:717,  status:'valid' },
  { cn:'ap02.yamada-lab.co.jp',    serial:'B3C4D5E6', key:'ECDSA P-384',  issued:'2026-03-01', expires:'2028-03-01', days:717,  status:'valid' },
  { cn:'ap-floor3.yamada-lab.co.jp',serial:'E5F6A7B8',key:'RSA 4096',     issued:'2025-03-22', expires:'2026-04-22', days:38,   status:'warn' },
  { cn:'proxy01.yamada-lab.co.jp', serial:'F6E5D4C3', key:'ECDSA P-384',  issued:'2025-04-15', expires:'2026-04-15', days:31,   status:'warn' },
  { cn:'ap-lobby.yamada-lab.co.jp',serial:'E5F6A7B9', key:'RSA 2048',     issued:'2025-03-07', expires:'2026-04-07', days:23,   status:'urgent' },
  { cn:'ap00.yamada-lab.co.jp',    serial:'0A1B2C3D', key:'RSA 2048',     issued:'2024-01-10', expires:'2025-01-10', days:null, status:'revoked' },
];
---

<Layout title="証明書管理 - YAMADA LAB ANP Portal">
  <div class="flex min-h-screen">
    <Sidebar current="certificates" />
    <div class="flex-1 p-7 overflow-x-hidden">

      <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
        <div>
          <h1 class="text-xl font-bold text-white">RadSec 証明書管理</h1>
          <p class="text-xs text-slate-500 mt-0.5">発行・失効・有効期限の一元管理</p>
        </div>
        <button class="flex items-center gap-2 px-4 py-2 rounded-xl bg-gradient-to-r from-blue-500 to-blue-700 text-white text-sm font-semibold shadow-lg shadow-blue-500/20">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          新規証明書を発行
        </button>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
        {[
          { label:'有効',               value:'21', color:'emerald' },
          { label:'30日以内に期限切れ', value:'3',  color:'amber' },
          { label:'期限切れ',           value:'1',  color:'red' },
          { label:'失効済み',           value:'2',  color:'slate' },
        ].map(s => (
          <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
            <div class="text-[11px] text-slate-500 mb-2">{s.label}</div>
            <div class={`text-3xl font-extrabold text-${s.color}-400`}>{s.value}</div>
          </div>
        ))}
      </div>

      <!-- Table -->
      <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl overflow-hidden">
        <div class="px-5 py-3 border-b border-[#1a2540] flex gap-2 flex-wrap items-center">
          <input placeholder="CN・シリアルで検索…" class="flex-1 min-w-[160px] px-3 py-2 rounded-lg bg-[#0f1a30]/80 border border-[#1a2540] text-white text-xs placeholder-slate-600 outline-none focus:border-blue-500/50 transition-all" />
          <select class="px-3 py-2 rounded-lg bg-[#0f1a30]/80 border border-[#1a2540] text-slate-400 text-xs outline-none">
            <option>全ステータス</option><option>有効</option><option>期限切れ間近</option><option>失効済み</option>
          </select>
          <button class="flex items-center gap-1.5 px-3 py-2 rounded-lg bg-[#0f1a30]/70 border border-[#1a2540] text-slate-500 text-xs hover:text-slate-300 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
            CA証明書DL
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#1a2540] bg-[#080e1c]/40">
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-5">Common Name</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">シリアル</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">鍵種別</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">発行日</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">有効期限</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">残日数</th>
                <th class="text-left text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-4">状態</th>
                <th class="text-right text-[11px] font-medium text-slate-500 uppercase tracking-wider py-3 px-5">操作</th>
              </tr>
            </thead>
            <tbody>
              {certs.map(c => (
                <tr class={`border-b border-[#1a2540]/50 hover:bg-[#0f1a30]/30 transition-colors`}>
                  <td class={`py-3 px-5 font-mono text-xs ${c.status === 'revoked' ? 'text-slate-500' : c.status === 'urgent' ? 'text-red-400' : c.status === 'warn' ? 'text-amber-400' : 'text-slate-200'}`}>{c.cn}</td>
                  <td class="py-3 px-4 font-mono text-[11px] text-slate-500">{c.serial}</td>
                  <td class="py-3 px-4"><span class="inline-flex px-2 py-0.5 rounded-full text-[10px] bg-slate-500/10 text-slate-400 border border-slate-500/20">{c.key}</span></td>
                  <td class={`py-3 px-4 text-xs ${c.status === 'revoked' ? 'text-slate-600' : 'text-slate-400'}`}>{c.issued}</td>
                  <td class={`py-3 px-4 text-xs ${c.status === 'urgent' ? 'text-red-400' : c.status === 'warn' ? 'text-amber-400' : c.status === 'revoked' ? 'text-slate-600' : 'text-slate-400'}`}>{c.expires}</td>
                  <td class="py-3 px-4">
                    {c.days !== null
                      ? <span class={`text-sm font-semibold ${c.status === 'urgent' ? 'text-red-400' : c.status === 'warn' ? 'text-amber-400' : 'text-emerald-400'}`}>{c.days}日</span>
                      : <span class="text-slate-600 text-sm">—</span>
                    }
                  </td>
                  <td class="py-3 px-4">
                    {c.status === 'valid'   && <span class="inline-flex px-2.5 py-0.5 rounded-full text-[11px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">有効</span>}
                    {c.status === 'warn'    && <span class="inline-flex px-2.5 py-0.5 rounded-full text-[11px] bg-amber-500/10 text-amber-400 border border-amber-500/20">期限切れ間近</span>}
                    {c.status === 'urgent'  && <span class="inline-flex px-2.5 py-0.5 rounded-full text-[11px] bg-red-500/10 text-red-400 border border-red-500/20">⚠ 要対応</span>}
                    {c.status === 'revoked' && <span class="inline-flex px-2.5 py-0.5 rounded-full text-[11px] bg-slate-500/10 text-slate-500 border border-slate-500/20">失効済み</span>}
                  </td>
                  <td class="py-3 px-5 text-right">
                    <div class="flex items-center justify-end gap-2">
                      {c.status !== 'revoked' && (
                        <button class="px-2.5 py-1 rounded-lg text-[11px] bg-[#0f1a30]/70 border border-[#1a2540] text-slate-500 hover:text-slate-300 transition-all">DL</button>
                      )}
                      {(c.status === 'warn' || c.status === 'urgent') && (
                        <button class="px-2.5 py-1 rounded-lg text-[11px] bg-gradient-to-r from-blue-500 to-blue-700 text-white border-none cursor-pointer">更新</button>
                      )}
                      {c.status === 'valid' && (
                        <button class="px-2.5 py-1 rounded-lg text-[11px] bg-red-500/10 text-red-400 border border-red-500/20 hover:bg-red-500/20 transition-all">失効</button>
                      )}
                      {c.status === 'revoked' && (
                        <button class="px-2.5 py-1 rounded-lg text-[11px] bg-[#0f1a30]/70 border border-[#1a2540] text-slate-600 cursor-not-allowed opacity-50">詳細</button>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Layout>
