---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="ダッシュボード - YAMADA LAB ANP Portal">
  <div class="flex min-h-screen">
    <Sidebar current="dashboard" />

    <div class="flex-1 p-7 overflow-x-hidden">
      <!-- Page header -->
      <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
        <div>
          <h1 class="text-xl font-bold text-white">ダッシュボード</h1>
          <p class="text-xs text-slate-500 mt-0.5">最終更新: 2026-03-15 20:52 JST</p>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            システム正常
          </span>
          <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[#0f1a30]/70 border border-[#1a2540] text-slate-500 text-xs hover:text-slate-300 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            更新
          </button>
        </div>
      </div>

      <!-- KPI cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
        <!-- Auth success rate -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3 text-[11px] text-slate-500">
            全体認証成功率
            <span class="text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full text-[10px]">▲ 0.3%</span>
          </div>
          <div class="text-3xl font-extrabold text-emerald-400 leading-none">97.4<span class="text-base font-semibold">%</span></div>
          <div class="mt-3 h-1.5 rounded-full bg-[#0f1a30] overflow-hidden">
            <div class="h-full rounded-full bg-gradient-to-r from-emerald-600 to-emerald-400" style="width:97.4%"></div>
          </div>
          <div class="text-[11px] text-slate-600 mt-1.5">過去24時間</div>
        </div>
        <!-- RADIUS -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="text-[11px] text-slate-500 mb-3">RADIUSサーバ</div>
          <div class="text-3xl font-extrabold text-white leading-none">4<span class="text-sm font-normal text-slate-500"> / 4</span></div>
          <div class="flex gap-2 mt-3">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">オンライン 4</span>
          </div>
          <div class="text-[11px] text-slate-600 mt-2">平均レスポンス 12ms</div>
        </div>
        <!-- Certs -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="text-[11px] text-slate-500 mb-3">証明書ステータス</div>
          <div class="text-3xl font-extrabold text-amber-400 leading-none">3<span class="text-sm font-normal text-slate-500"> 件</span></div>
          <div class="mt-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] bg-amber-500/10 text-amber-400 border border-amber-500/20">30日以内に期限切れ</span>
          </div>
          <div class="text-[11px] text-slate-600 mt-2">有効 21 / 失効 2</div>
        </div>
        <!-- Clients -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="text-[11px] text-slate-500 mb-3">RadSecクライアント</div>
          <div class="text-3xl font-extrabold text-blue-400 leading-none">18</div>
          <div class="mt-3">
            <div class="flex justify-between text-[11px] text-slate-500 mb-1"><span>今日の認証数</span><span class="text-blue-400">24,831</span></div>
            <div class="h-1.5 rounded-full bg-[#0f1a30] overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-blue-600 to-cyan-400" style="width:68%"></div></div>
          </div>
        </div>
      </div>

      <!-- Row 2: Auth chart + RADIUS status -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <!-- Auth success rate chart (7 days) -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="flex items-start justify-between mb-4">
            <div>
              <div class="text-sm font-semibold text-white">認証成功率（過去7日）</div>
              <div class="text-[11px] text-slate-500 mt-0.5">全クライアント合計</div>
            </div>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">正常</span>
          </div>
          <div class="flex items-end gap-1.5 h-20 mb-2">
            {[
              { d:'3/9',  v:97 },
              { d:'3/10', v:95 },
              { d:'3/11', v:96 },
              { d:'3/12', v:82, warn:true },
              { d:'3/13', v:97 },
              { d:'3/14', v:98 },
              { d:'今日',  v:97, today:true },
            ].map(bar => (
              <div class="flex-1 flex flex-col items-center gap-1">
                <div class="w-full relative rounded-t" style={`height:${bar.v * 0.8}%`}>
                  <div
                    class={`absolute inset-0 rounded-t ${
                      bar.today
                        ? 'bg-gradient-to-t from-emerald-600 to-emerald-400'
                        : bar.warn
                        ? 'bg-gradient-to-t from-amber-700 to-amber-500'
                        : 'bg-gradient-to-t from-blue-700 to-blue-500'
                    }`}
                  ></div>
                </div>
                <span class={`text-[9px] ${bar.today ? 'text-blue-400 font-semibold' : 'text-slate-600'}`}>{bar.d}</span>
              </div>
            ))}
          </div>
          <div class="flex justify-between text-[11px] text-slate-600 pt-3 border-t border-[#1a2540]">
            <span>7日平均: <span class="text-slate-400">96.1%</span></span>
            <span>最低: <span class="text-amber-400">92.4%</span> (3/12)</span>
          </div>
        </div>

        <!-- RADIUS quick list -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="text-sm font-semibold text-white">RADIUSサーバ</div>
            <a href="/radius" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">詳細 →</a>
          </div>
          <div class="space-y-2.5">
            {[
              { host:'radius01.yamada-lab.co.jp', ms:8 },
              { host:'radius02.yamada-lab.co.jp', ms:11 },
              { host:'radius-dr.osakadc.jp',      ms:22 },
              { host:'radsec-gw.yamada-lab.co.jp',ms:6 },
            ].map(s => (
              <div class="flex items-center justify-between px-3.5 py-2.5 rounded-xl bg-[#0f1a30]/60 border border-[#1a2540]">
                <div class="flex items-center gap-2.5">
                  <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></div>
                  <span class="font-mono text-xs text-slate-300">{s.host}</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[11px] text-slate-500">{s.ms}ms</span>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">正常</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Row 3: Expiring certs + Recent events -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- Expiring certs -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="text-sm font-semibold text-white">期限切れ間近の証明書</div>
            <a href="/certificates" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">一覧 →</a>
          </div>
          <div class="space-y-2">
            {[
              { cn:'ap-lobby.yamada-lab.co.jp',   exp:'2026-04-07', days:23, urgent:true },
              { cn:'proxy01.yamada-lab.co.jp',    exp:'2026-04-15', days:31, urgent:false },
              { cn:'ap-floor3.yamada-lab.co.jp',  exp:'2026-04-22', days:38, urgent:false },
            ].map(c => (
              <div class={`flex items-center justify-between px-3.5 py-2.5 rounded-xl border ${c.urgent ? 'bg-red-500/5 border-red-500/15' : 'bg-amber-500/5 border-amber-500/15'}`}>
                <div>
                  <div class={`text-xs font-mono ${c.urgent ? 'text-red-400' : 'text-amber-400'}`}>{c.cn}</div>
                  <div class="text-[10px] text-slate-500 mt-0.5">期限: {c.exp}</div>
                </div>
                <span class={`inline-flex px-2.5 py-0.5 rounded-full text-[11px] font-semibold ${c.urgent ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}`}>
                  {c.days}日
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Recent events -->
        <div class="bg-[#0d1627]/60 border border-[#1a2540] rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="text-sm font-semibold text-white">最近の認証イベント</div>
            <a href="/logs" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">ログ →</a>
          </div>
          <div class="space-y-0">
            {[
              { user:'user@yamada-lab.co.jp',       via:'ap01 EAP-TLS',  ok:true,  time:'20:51' },
              { user:'device@partner.example.com',  via:'proxy01 RadSec',ok:true,  time:'20:50' },
              { user:'unknown@guest.net',            via:'証明書失効',     ok:false, time:'20:49' },
              { user:'bob@yamada-lab.co.jp',         via:'ap02 EAP-TLS',  ok:true,  time:'20:48' },
              { user:'alice@yamada-lab.co.jp',       via:'ap03 EAP-TTLS', ok:true,  time:'20:47' },
            ].map(e => (
              <div class="flex items-center gap-2.5 py-2 border-b border-[#1a2540]/60 last:border-0">
                <div class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${e.ok ? 'bg-emerald-400' : 'bg-red-400'}`}></div>
                <div class="flex-1 min-w-0">
                  <div class="text-xs text-slate-300 font-mono truncate">{e.user}</div>
                  <div class={`text-[10px] mt-0.5 ${e.ok ? 'text-slate-500' : 'text-red-400'}`}>{e.via}</div>
                </div>
                <span class="text-[10px] text-slate-600 flex-shrink-0">{e.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
