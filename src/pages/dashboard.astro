---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="ダッシュボード - YAMADA LAB Certificate Portal">
  <Header slot="header" isAuthenticated={true} />
  <Footer slot="footer" />

  <div class="min-h-screen pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">

      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-white">ダッシュボード</h1>
        <p class="text-sm text-slate-400 mt-1">OpenRoaming RadSec 証明書管理</p>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Active Certificates -->
        <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400">有効な証明書</p>
              <p class="text-2xl font-bold text-white" id="stat-active">—</p>
            </div>
          </div>
        </div>

        <!-- Expiring Soon -->
        <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400">期限切れ間近</p>
              <p class="text-2xl font-bold text-white" id="stat-expiring">—</p>
            </div>
          </div>
        </div>

        <!-- Revoked -->
        <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400">失効済み</p>
              <p class="text-2xl font-bold text-white" id="stat-revoked">—</p>
            </div>
          </div>
        </div>

        <!-- Total Issued -->
        <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400">総発行数</p>
              <p class="text-2xl font-bold text-white" id="stat-total">—</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions + Recent Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Quick Actions -->
        <div class="lg:col-span-1">
          <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-6">
            <h2 class="text-sm font-semibold text-white mb-4">クイックアクション</h2>
            <div class="space-y-3">
              <a
                href="/issue"
                class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-brand-500/10 to-brand-600/10 border border-brand-500/20 text-brand-300 hover:from-brand-500/20 hover:to-brand-600/20 transition-all group"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <span class="text-sm font-medium">新規証明書を発行</span>
                <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </a>

              <a
                href="/certificates"
                class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-800/40 border border-slate-700/40 text-slate-300 hover:bg-slate-800/60 transition-all group"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <span class="text-sm font-medium">証明書一覧を確認</span>
                <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </a>

              <button
                id="download-ca-btn"
                class="w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-800/40 border border-slate-700/40 text-slate-300 hover:bg-slate-800/60 transition-all group text-left"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                <span class="text-sm font-medium">CA証明書ダウンロード</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Recent Certificates -->
        <div class="lg:col-span-2">
          <div class="bg-slate-900/60 backdrop-blur border border-slate-800/60 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">最近発行された証明書</h2>
              <a href="/certificates" class="text-xs text-brand-400 hover:text-brand-300 transition-colors">すべて表示 →</a>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-800/60">
                    <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider py-3 px-2">CN</th>
                    <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider py-3 px-2">シリアル</th>
                    <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider py-3 px-2">有効期限</th>
                    <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider py-3 px-2">状態</th>
                  </tr>
                </thead>
                <tbody id="recent-certs">
                  <tr>
                    <td colspan="4" class="py-12 text-center text-slate-500 text-sm">
                      まだ証明書が発行されていません
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
