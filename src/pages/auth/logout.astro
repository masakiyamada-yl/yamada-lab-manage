---
// ログアウト: SW が /cdn-cgi/access/logout にリダイレクト
// SW が無効の場合のフォールバック
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ログアウト - YAMADA LAB ANP Portal">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <div class="inline-block w-10 h-10 border-4 border-slate-500/30 border-t-slate-500 rounded-full animate-spin mb-4"></div>
      <p class="text-slate-400 text-sm">ログアウト中...</p>
    </div>
  </div>
  <script>
    window.location.replace("/cdn-cgi/access/logout");
  </script>
</Layout>
