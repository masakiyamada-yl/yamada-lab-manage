---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="YAMADA LAB - OpenRoaming RadSec 証明書管理ポータル">
  <Header slot="header" isAuthenticated={false} />
  <Footer slot="footer" />

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center px-4 overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>
      <!-- Grid -->
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-slate-700/60 bg-slate-900/60 backdrop-blur mb-8 animate-fade-up">
        <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
        <span class="text-xs text-slate-400">OpenRoaming RadSec Certificate Portal</span>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 animate-fade-up animation-delay-100">
        RadSec証明書を
        <br />
        <span class="bg-gradient-to-r from-brand-400 to-cyan-400 bg-clip-text text-transparent">
          安全に管理・発行
        </span>
      </h1>

      <p class="text-lg text-slate-400 max-w-xl mx-auto mb-10 animate-fade-up animation-delay-200">
        OpenRoaming対応のRadSecクライアント証明書を
        <br class="hidden sm:block" />
        ワンストップで発行・管理するポータルサイト
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up animation-delay-300">
        <a
          href="/auth"
          class="px-8 py-3.5 rounded-xl bg-gradient-to-r from-brand-500 to-brand-600 text-white font-medium hover:from-brand-400 hover:to-brand-500 transition-all shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40"
        >
          トークンで認証する
        </a>
        <a
          href="#features"
          class="px-8 py-3.5 rounded-xl border border-slate-700/60 text-slate-300 hover:bg-slate-900/60 hover:text-white transition-all"
        >
          機能を見る
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" aria-hidden="true">
      <span class="text-xs text-slate-600">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-600 to-transparent"></div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">主な機能</h2>
        <p class="text-slate-400">セキュアな証明書ライフサイクル管理</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="bg-slate-900/40 backdrop-blur border border-slate-800/40 rounded-2xl p-6 hover:border-slate-700/60 transition-all group">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-all">
            <svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">ワンクリック発行</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            CN・組織名・有効期間を指定するだけで、PEMまたはPKCS#12形式の証明書を即座に生成・ダウンロード。
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-slate-900/40 backdrop-blur border border-slate-800/40 rounded-2xl p-6 hover:border-slate-700/60 transition-all group">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-all">
            <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">ライフサイクル管理</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            発行済み証明書の一覧表示、期限監視、失効処理。期限切れ間近の証明書をダッシュボードで即座に把握。
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-slate-900/40 backdrop-blur border border-slate-800/40 rounded-2xl p-6 hover:border-slate-700/60 transition-all group">
          <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center mb-4 group-hover:bg-violet-500/20 transition-all">
            <svg class="w-6 h-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">トークン認証</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            招待制トークンによるアクセス制御。パートナーやクライアントに必要な権限のみを安全に付与。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Spec Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 border-t border-slate-800/30">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl font-bold text-white mb-8 text-center">対応仕様</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="text-center p-4 rounded-xl bg-slate-900/30 border border-slate-800/30">
          <p class="text-sm font-semibold text-white">RadSec</p>
          <p class="text-xs text-slate-500 mt-1">RFC 6614</p>
        </div>
        <div class="text-center p-4 rounded-xl bg-slate-900/30 border border-slate-800/30">
          <p class="text-sm font-semibold text-white">OpenRoaming</p>
          <p class="text-xs text-slate-500 mt-1">WBA Spec</p>
        </div>
        <div class="text-center p-4 rounded-xl bg-slate-900/30 border border-slate-800/30">
          <p class="text-sm font-semibold text-white">X.509 v3</p>
          <p class="text-xs text-slate-500 mt-1">RSA / ECDSA</p>
        </div>
        <div class="text-center p-4 rounded-xl bg-slate-900/30 border border-slate-800/30">
          <p class="text-sm font-semibold text-white">PKCS#12</p>
          <p class="text-xs text-slate-500 mt-1">PEM / P12</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.6s ease-out forwards;
    opacity: 0;
  }
  .animation-delay-100 {
    animation-delay: 0.1s;
  }
  .animation-delay-200 {
    animation-delay: 0.2s;
  }
  .animation-delay-300 {
    animation-delay: 0.3s;
  }
</style>
