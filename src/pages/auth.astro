---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="トークン認証 - YAMADA LAB Certificate Portal">
  <Header slot="header" isAuthenticated={false} />
  <Footer slot="footer" />

  <div class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
    <!-- Background decorations -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-brand-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative w-full max-w-md">
      <!-- Card -->
      <div class="bg-slate-900/60 backdrop-blur-xl border border-slate-800/60 rounded-2xl p-8 shadow-2xl">
        <!-- Icon -->
        <div class="flex justify-center mb-6">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center shadow-lg shadow-brand-500/30">
            <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
        </div>

        <h1 class="text-xl font-bold text-center text-white mb-2">
          証明書管理ポータル
        </h1>
        <p class="text-sm text-slate-400 text-center mb-8">
          招待トークンを入力してアクセスしてください
        </p>

        <!-- Form -->
        <form id="auth-form" class="space-y-5">
          <div>
            <label for="token-input" class="block text-sm font-medium text-slate-300 mb-2">
              アクセストークン
            </label>
            <input
              id="token-input"
              type="text"
              placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
              autocomplete="off"
              spellcheck="false"
              class="w-full px-4 py-3 rounded-xl bg-slate-800/60 border border-slate-700/60 text-white placeholder-slate-500 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500/50 transition-all"
            />
          </div>

          <!-- Error message -->
          <div id="auth-error" class="hidden">
            <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <span id="auth-error-msg">無効なトークンです</span>
            </div>
          </div>

          <button
            type="submit"
            class="w-full py-3 rounded-xl bg-gradient-to-r from-brand-500 to-brand-600 text-white font-medium text-sm hover:from-brand-400 hover:to-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50 transition-all shadow-lg shadow-brand-500/25 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="auth-btn-text">認証する</span>
            <span id="auth-btn-loading" class="hidden">
              <svg class="animate-spin inline w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              認証中...
            </span>
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-slate-800/60">
          <p class="text-xs text-slate-500 text-center">
            トークンは管理者から発行されます。
            <br />
            お持ちでない場合は
            <a href="https://yamada-lab.co.jp/#contact" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 transition-colors">
              お問い合わせ
            </a>
            ください。
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('auth-form') as HTMLFormElement;
  const tokenInput = document.getElementById('token-input') as HTMLInputElement;
  const errorDiv = document.getElementById('auth-error') as HTMLDivElement;
  const errorMsg = document.getElementById('auth-error-msg') as HTMLSpanElement;
  const btnText = document.getElementById('auth-btn-text') as HTMLSpanElement;
  const btnLoading = document.getElementById('auth-btn-loading') as HTMLSpanElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = tokenInput.value.trim();

    if (!token) {
      errorDiv.classList.remove('hidden');
      errorMsg.textContent = 'トークンを入力してください';
      return;
    }

    // Show loading
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    errorDiv.classList.add('hidden');

    try {
      const res = await fetch('/api/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });

      if (res.ok) {
        window.location.href = '/dashboard';
      } else {
        const data = await res.json().catch(() => ({}));
        errorDiv.classList.remove('hidden');
        errorMsg.textContent = data.message || '無効なトークンです';
      }
    } catch {
      errorDiv.classList.remove('hidden');
      errorMsg.textContent = 'サーバーに接続できません';
    } finally {
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>
