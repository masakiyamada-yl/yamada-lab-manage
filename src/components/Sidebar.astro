---
interface Props {
  current: 'dashboard' | 'analytics' | 'radius' | 'radius-udp' | 'certificates' | 'logs';
}
const { current } = Astro.props;

const navItems = [
  {
    section: 'メイン',
    items: [
      { id: 'dashboard', label: 'ダッシュボード', href: '/dashboard', icon: 'home' },
      { id: 'analytics', label: '認証分析', href: '/analytics', icon: 'chart' },
    ],
  },
  {
    section: 'インフラ',
    items: [
      { id: 'radius', label: 'RADIUS (RadSec)', href: '/radius', icon: 'server' },
      { id: 'radius-udp', label: 'RADIUS (UDP)', href: '/radius-udp', icon: 'udp' },
      { id: 'certificates', label: '証明書管理', href: '/certificates', icon: 'shield' },
    ],
  },
  {
    section: '監査',
    items: [
      { id: 'logs', label: 'ログ', href: '/logs', icon: 'list' },
    ],
  },
];
---

<aside
  class="w-[220px] min-h-[calc(100vh-0px)] bg-[#060c18] border-r border-[#1a2540] flex flex-col sticky top-0 h-screen overflow-y-auto flex-shrink-0"
  aria-label="サイドバーナビゲーション"
>
  <!-- Logo -->
  <div class="flex items-center gap-3 px-4 py-5 border-b border-[#1a2540]">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center flex-shrink-0 shadow-lg shadow-blue-500/20">
      <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    <div>
      <div class="text-sm font-bold text-white leading-tight">YAMADA LAB</div>
      <div class="text-[10px] text-slate-500 leading-tight">ANP Portal</div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 space-y-5">
    {navItems.map((group) => (
      <div>
        <p class="text-[10px] font-semibold text-slate-600 uppercase tracking-widest px-2 mb-2">{group.section}</p>
        <ul class="space-y-1">
          {group.items.map((item) => (
            <li>
              <a
                href={item.href}
                class={`flex items-center gap-2.5 px-2.5 py-2 rounded-xl text-[13px] transition-all ${
                  current === item.id
                    ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
                    : 'text-slate-500 hover:bg-[#0f1a30] hover:text-slate-300'
                }`}
                aria-current={current === item.id ? 'page' : undefined}
              >
                {item.icon === 'home' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                )}
                {item.icon === 'chart' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                )}
                {item.icon === 'server' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
                )}
                {item.icon === 'shield' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                )}
                {item.icon === 'udp' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                )}
                {item.icon === 'list' && (
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                )}
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <!-- User / Logout -->
  <div class="px-3 py-4 border-t border-[#1a2540]">
    <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-xl bg-[#0f1a30]/50 mb-2">
      <div class="w-7 h-7 rounded-full bg-blue-500/20 flex items-center justify-center text-xs font-bold text-blue-400">Y</div>
      <div class="flex-1 min-w-0">
        <div class="text-xs font-medium text-slate-300 truncate">yamada@yamada-lab.co.jp</div>
        <div class="text-[10px] text-slate-500">ANP管理者</div>
      </div>
    </div>
    <a href="/auth/logout/" class="flex items-center gap-2.5 px-2.5 py-2 rounded-xl text-[13px] text-slate-500 hover:bg-[#0f1a30] hover:text-slate-300 transition-all">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      ログアウト
    </a>
  </div>
</aside>
